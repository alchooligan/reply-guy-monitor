<?xml version="1.0" encoding="UTF-16"?>
<Task version="1.2" xmlns="http://schemas.microsoft.com/windows/2004/02/mit/task">
  <RegistrationInfo>
    <Description>Reply Guy Monitor - Telegram command listener (starts at login)</Description>
  </RegistrationInfo>
  <Triggers>
    <LogonTrigger>
      <Enabled>true</Enabled>
    </LogonTrigger>
  </Triggers>
  <Settings>
    <MultipleInstancesPolicy>IgnoreNew</MultipleInstancesPolicy>
    <DisallowStartIfOnBatteries>false</DisallowStartIfOnBatteries>
    <StopIfGoingOnBatteries>false</StopIfGoingOnBatteries>
    <ExecutionTimeLimit>PT0S</ExecutionTimeLimit>
    <Priority>7</Priority>
  </Settings>
  <Actions Context="Author">
    <Exec>
      <!-- Update these three paths before importing the task -->
      <Command>C:\path\to\python.exe</Command>
      <Arguments>C:\path\to\reply-guy-monitor\scripts\tg_listener.py</Arguments>
      <WorkingDirectory>C:\path\to\reply-guy-monitor</WorkingDirectory>
    </Exec>
  </Actions>
</Task>
